{
  "manifest_version": 3,
  "name": "Google Docs offline",
  "version": "0.1.0",
  "description": "Edit, create and view your documents, spreadsheets and presentations - all without Internet access.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "proxy"
  ],
  "icons": {
    "16": "icons/download.png",
    "32": "icons/download.png",
    "48": "icons/download.png",
    "128": "icons/download.png"
  },
  "action": {
    "default_title": "Google Docs offline",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/download.png",
      "32": "icons/download.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "windows": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y",
        "linux": "Ctrl+Shift+Y",
        "chromeos": "Ctrl+Shift+Y"
      }
    },
    "remove_extension": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Remove this extension from Chrome"
    }
  }
}
